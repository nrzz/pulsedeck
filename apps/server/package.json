{
  "name": "@pulsedeck/server",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/static": "^8.0.3",
    "@fastify/websocket": "^11.0.1",
    "@pulsedeck/shared": "*",
    "fastify": "^5.2.0",
    "ping": "^0.4.4",
    "systeminformation": "^5.23.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/ping": "^0.4.4",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
